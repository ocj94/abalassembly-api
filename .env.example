# ─── Copier en .env et remplir. NE JAMAIS committer .env ───

# Serveur
PORT=3000
NODE_ENV=production

# Origines autorisées (CORS) — séparées par des virgules
CORS_ORIGINS=https://ocj94.github.io,https://abalassembly.fr

# PostgreSQL (hébergeur UE : Scaleway, Clever Cloud…)
DATABASE_URL=postgres://user:password@localhost:5432/abalassembly

# Redis (sessions, rate-limit, leaderboard)
REDIS_URL=redis://localhost:6379

# Secret JWT — générer avec :  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_bytes_hex_minimum

# Email d'un compte admin de démarrage (reçoit le rôle admin à l'inscription)
BOOTSTRAP_ADMIN_EMAIL=

# Certificat CA PostgreSQL de l'hébergeur (contenu PEM) — active la vérification
# TLS stricte. À télécharger dans la console Scaleway/Clever. Fortement recommandé.
DATABASE_CA=
