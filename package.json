{
  "name": "abalassembly-api",
  "version": "0.1.0",
  "description": "Backend dormant d'Abalassembly — Fastify + PostgreSQL + Redis, RGPD-ready",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": { "node": ">=20.6" },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node migrations/run.js",
    "purge": "node -e \"import('./src/jobs/purge.js').then(m=>m.runPurge()).then(()=>process.exit(0))\"",
    "pretest": "node --env-file=.env.test migrations/run.js",
    "test": "node --env-file=.env.test --test --test-concurrency=1 test/*.test.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "argon2": "^0.41.1",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  }
}
