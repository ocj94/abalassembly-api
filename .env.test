# Environnement de TEST uniquement — valeurs locales, sans secret réel.
# Utilisé par `npm test` (voir package.json). Ne jamais utiliser ces valeurs
# en production : JWT_SECRET doit être un secret aléatoire propre à chaque
# environnement (voir .env.example).
DATABASE_URL=postgresql://aba_test:aba_test@localhost:5432/abalassembly_test
REDIS_URL=redis://localhost:6379
JWT_SECRET=test-secret-do-not-use-in-production-min-32-chars
NODE_ENV=test
PORT=3000
CORS_ORIGINS=http://localhost:3000
BOOTSTRAP_ADMIN_EMAIL=admin@test.abalassembly.local
